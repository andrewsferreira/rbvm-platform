# =============================================================================
# RiskBridge — Environment Variables (.env.example)
# © 2026 Andrews Ferreira. Todos os direitos reservados.
# NEVER commit the real .env to any public repository.
# =============================================================================

# ── SUPABASE ──────────────────────────────────────────────────────────────────
# Project URL — safe to expose in frontend (anon key only)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon/public key — safe for frontend (RLS enforced on all tables)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role key — NEVER expose in frontend, server-side only
# Used only in Edge Functions or secure server routes
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── APP ───────────────────────────────────────────────────────────────────────
VITE_APP_NAME=RiskBridge
VITE_APP_VERSION=1.0.0-beta
VITE_APP_ENV=production

# Public demo URL (GitHub Pages)
VITE_PUBLIC_DEMO_URL=https://andrewsferreira.github.io/rbvm-platform/

# ── VERCEL (set in Vercel dashboard, not here) ────────────────────────────────
# VERCEL_URL is auto-injected by Vercel
# VERCEL_ENV is auto-injected by Vercel (preview | production | development)

# ── FEATURE FLAGS ─────────────────────────────────────────────────────────────
VITE_ENABLE_MOCK_DATA=true
VITE_ENABLE_AI_AGENT=true
VITE_ENABLE_EXPORT_REPORTS=true

# ── AUTH ──────────────────────────────────────────────────────────────────────
# Redirect URL after login (must be registered in Supabase Auth settings)
VITE_AUTH_REDIRECT_URL=https://riskbridge.vercel.app/app/dashboard

# ── SECURITY (never expose these) ────────────────────────────────────────────
# These belong ONLY in server-side Edge Functions
# SUPABASE_JWT_SECRET=your-jwt-secret
# ENCRYPTION_KEY=your-encryption-key
